# ─────────────────────────────────────────────────────────────────────────────
# Bolna → Slack Integration — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# Slack Bot OAuth token — get from: https://api.slack.com/apps
SLACK_BOT_TOKEN=your-slack-bot-token-here

# Slack channel ID (e.g. C08XXXXXXXXX)
SLACK_CHANNEL_ID=your-slack-channel-id-here

# Optional: shared secret for verifying Bolna webhook requests
BOLNA_WEBHOOK_SECRET=

# Port for the server
PORT=8000